# Copy this file to .env (which stays out of git) and fill in the two values
# from your Supabase dashboard: Project Settings -> Data API.
# Without them the app still works, but only saves to this browser
# (no cloud backup, no save-code restore on other devices).

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
